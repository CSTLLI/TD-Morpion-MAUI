<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TD_Morpion_MAUI.MainPage"
             BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#1A1A2E}">

    <VerticalStackLayout
        Padding="20"
        Spacing="20"
        VerticalOptions="Center"
        HorizontalOptions="Center">

        <Label
            x:Name="TitleLabel"
            Text="Morpion"
            FontSize="36"
            FontAttributes="Bold"
            HorizontalOptions="Center"
            TextColor="{AppThemeBinding Light=#333333, Dark=#EEEEEE}" />

        <Label
            x:Name="StatusLabel"
            Text="Au tour de X"
            FontSize="22"
            FontAttributes="Bold"
            HorizontalOptions="Center"
            TextColor="{AppThemeBinding Light=#512BD4, Dark=#B39DDB}" />

        <Grid
            x:Name="GameGrid"
            RowDefinitions="100,100,100"
            ColumnDefinitions="100,100,100"
            RowSpacing="5"
            ColumnSpacing="5"
            HorizontalOptions="Center">

            <Button Grid.Row="0" Grid.Column="0" x:Name="Btn0" Clicked="OnCellClicked"
                    FontSize="40" FontAttributes="Bold" WidthRequest="100" HeightRequest="100"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#16213E}"
                    TextColor="#333333" CornerRadius="10" />
            <Button Grid.Row="0" Grid.Column="1" x:Name="Btn1" Clicked="OnCellClicked"
                    FontSize="40" FontAttributes="Bold" WidthRequest="100" HeightRequest="100"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#16213E}"
                    TextColor="#333333" CornerRadius="10" />
            <Button Grid.Row="0" Grid.Column="2" x:Name="Btn2" Clicked="OnCellClicked"
                    FontSize="40" FontAttributes="Bold" WidthRequest="100" HeightRequest="100"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#16213E}"
                    TextColor="#333333" CornerRadius="10" />

            <Button Grid.Row="1" Grid.Column="0" x:Name="Btn3" Clicked="OnCellClicked"
                    FontSize="40" FontAttributes="Bold" WidthRequest="100" HeightRequest="100"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#16213E}"
                    TextColor="#333333" CornerRadius="10" />
            <Button Grid.Row="1" Grid.Column="1" x:Name="Btn4" Clicked="OnCellClicked"
                    FontSize="40" FontAttributes="Bold" WidthRequest="100" HeightRequest="100"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#16213E}"
                    TextColor="#333333" CornerRadius="10" />
            <Button Grid.Row="1" Grid.Column="2" x:Name="Btn5" Clicked="OnCellClicked"
                    FontSize="40" FontAttributes="Bold" WidthRequest="100" HeightRequest="100"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#16213E}"
                    TextColor="#333333" CornerRadius="10" />

            <Button Grid.Row="2" Grid.Column="0" x:Name="Btn6" Clicked="OnCellClicked"
                    FontSize="40" FontAttributes="Bold" WidthRequest="100" HeightRequest="100"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#16213E}"
                    TextColor="#333333" CornerRadius="10" />
            <Button Grid.Row="2" Grid.Column="1" x:Name="Btn7" Clicked="OnCellClicked"
                    FontSize="40" FontAttributes="Bold" WidthRequest="100" HeightRequest="100"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#16213E}"
                    TextColor="#333333" CornerRadius="10" />
            <Button Grid.Row="2" Grid.Column="2" x:Name="Btn8" Clicked="OnCellClicked"
                    FontSize="40" FontAttributes="Bold" WidthRequest="100" HeightRequest="100"
                    BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#16213E}"
                    TextColor="#333333" CornerRadius="10" />
        </Grid>

        <Button
            x:Name="ResetBtn"
            Text="Nouvelle partie"
            Clicked="OnResetClicked"
            FontSize="18"
            BackgroundColor="#512BD4"
            TextColor="White"
            CornerRadius="10"
            Padding="20,10"
            HorizontalOptions="Center" />
    </VerticalStackLayout>

</ContentPage>
